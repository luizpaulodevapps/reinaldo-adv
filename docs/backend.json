
{
  "entities": {
    "Client": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Client",
      "type": "object",
      "description": "Represents a client (either individual or corporate) of the legal firm, storing their complete registration information.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "documentNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zipCode": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "documentNumber", "type", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "System-wide notification for users.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["deadline", "hearing", "lead", "financial", "system", "reimbursement"] },
        "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
        "read": { "type": "boolean" },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AuditLog": {
      "title": "AuditLog",
      "type": "object",
      "description": "Security log for traceability of all critical actions.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string", "enum": ["create", "update", "delete", "login", "export", "approve", "refuse"] },
        "collection": { "type": "string" },
        "docId": { "type": "string" },
        "ip": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Reimbursement": {
      "title": "Reimbursement",
      "type": "object",
      "description": "A request for expense reimbursement by a staff member.",
      "properties": {
        "id": { "type": "string" },
        "requesterId": { "type": "string" },
        "requesterName": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Viagem", "Refeição", "Cópias", "Custas Judiciais", "Outros"] },
        "status": { "type": "string", "enum": ["Pendente", "Aprovado", "Recusado", "Pago"] },
        "date": { "type": "string", "format": "date" },
        "destinationAccount": { "type": "string" },
        "originAccount": { "type": "string" },
        "refusalReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "FinancialTitle": {
      "title": "FinancialTitle",
      "type": "object",
      "description": "Financial entry for the legal firm (income or expense).",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Entrada (Receita)", "Saída (Despesa)"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "value": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pendente", "Pago", "Recebido", "Liquidado", "Cancelado"] },
        "originBank": { "type": "string" },
        "destinationBank": { "type": "string" },
        "responsibleStaffId": { "type": "string" },
        "clientName": { "type": "string" },
        "processNumber": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "/notifications/{notificationId}": { "schema": { "$ref": "#/backend/entities/Notification" }, "description": "User notifications." },
    "/audit_logs/{logId}": { "schema": { "$ref": "#/backend/entities/AuditLog" }, "description": "Security audit logs." },
    "/staff_profiles/{staffId}": { "schema": { "$ref": "#/backend/entities/StaffProfile" }, "description": "Staff access and roles." },
    "/employees/{employeeId}": { "schema": { "$ref": "#/backend/entities/StaffProfile" }, "description": "Detailed DP records." },
    "/clients/{clientId}": { "schema": { "$ref": "#/backend/entities/Client" }, "description": "Client registration data." },
    "/processes/{processId}": { "schema": { "$ref": "#/backend/entities/Process" }, "description": "Legal process details." },
    "/reimbursements/{reimbursementId}": { "schema": { "$ref": "#/backend/entities/Reimbursement" }, "description": "Staff reimbursement requests." },
    "/financial_titles/{titleId}": { "schema": { "$ref": "#/backend/entities/FinancialTitle" }, "description": "Financial entries." }
  }
}
