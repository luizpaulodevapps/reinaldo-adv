
{
  "entities": {
    "Client": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Client",
      "type": "object",
      "description": "Represents a client (either individual or corporate) of the legal firm, storing their complete registration information.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "documentNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zipCode": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "documentNumber", "type", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "System-wide notification for users.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["deadline", "hearing", "lead", "financial", "system"] },
        "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
        "read": { "type": "boolean" },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Interview": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Interview",
      "type": "object",
      "description": "Captured details from a potential client intake or witness interview.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "type": { "type": "string", "enum": ["Inicial Trabalhista", "Cível", "Preparação de Testemunha"] },
        "status": { "type": "string", "enum": ["Em Rascunho", "Concluída", "Convertida em Processo"] },
        "interviewerId": { "type": "string" },
        "data": { "type": "object" },
        "aiSummary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Activity": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Activity",
      "type": "object",
      "description": "A CRM activity related to a lead or client.",
      "properties": {
        "id": { "type": "string" },
        "leadId": { "type": "string" },
        "type": { "type": "string", "enum": ["Lembrete", "Reunião", "Ligação", "E-mail", "WhatsApp", "Nota"] },
        "responsibleId": { "type": "string" },
        "responsibleName": { "type": "string" },
        "subject": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Planejado", "Realizado", "Cancelado"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "StaffProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StaffProfile",
      "type": "object",
      "description": "Represents a legal team member.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "isActive": { "type": "boolean" },
        "themePreferences": { "type": "object" }
      }
    },
    "Process": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Process",
      "type": "object",
      "description": "Details of a legal process.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "processNumber": { "type": "string" },
        "caseType": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "court": { "type": "string" },
        "vara": { "type": "string" },
        "courtAddress": { "type": "string" },
        "defendantName": { "type": "string" },
        "defendantDocument": { "type": "string" },
        "defendantAddress": { "type": "string" },
        "responsibleStaffId": { "type": "string" },
        "responsibleStaffName": { "type": "string" },
        "strategyNotes": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "value": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Diligence": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Diligence",
      "type": "object",
      "description": "A task or diligence to be performed by a staff member.",
      "properties": {
        "id": { "type": "string" },
        "processId": { "type": "string" },
        "processNumber": { "type": "string" },
        "clientName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "assigneeId": { "type": "string" },
        "assigneeName": { "type": "string" },
        "status": { "type": "string", "enum": ["Pendente", "Em Andamento", "Concluída"] },
        "type": { "type": "string", "enum": ["Física", "Virtual"] },
        "location": { "type": "string" },
        "requiresSubestabelecimento": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "FinancialTitle": {
      "title": "FinancialTitle",
      "type": "object",
      "description": "Financial entry for the legal firm (income or expense).",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Entrada (Receita)", "Saída (Despesa)"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "value": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pendente", "Pago", "Recebido", "Cancelado"] },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "entityName": { "type": "string" },
        "processNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "/notifications/{notificationId}": { "schema": { "$ref": "#/backend/entities/Notification" }, "description": "User notifications." },
    "/staff_profiles/{staffId}": { "schema": { "$ref": "#/backend/entities/StaffProfile" }, "description": "Staff profiles." },
    "/clients/{clientId}": { "schema": { "$ref": "#/backend/entities/Client" }, "description": "Client registration data." },
    "/processes/{processId}": { "schema": { "$ref": "#/backend/entities/Process" }, "description": "Legal process details." },
    "/interviews/{interviewId}": { "schema": { "$ref": "#/backend/entities/Interview" }, "description": "Client intake interviews." },
    "/diligences/{diligenceId}": { "schema": { "$ref": "#/backend/entities/Diligence" }, "description": "Legal diligences and tasks." },
    "/financial_titles/{titleId}": { "schema": { "$ref": "#/backend/entities/FinancialTitle" }, "description": "Financial entries." },
    "/activities/{activityId}": { "schema": { "$ref": "#/backend/entities/Activity" }, "description": "Lead and client CRM activities." },
    "/courts/{courtId}": { "schema": { "$ref": "#/backend/entities/Court" }, "description": "Judicial organs and buildings registry." },
    "/freelancers/{freelancerId}": { "schema": { "$ref": "#/backend/entities/Freelancer" }, "description": "Registry of freelance correspondents." },
    "/counterparties/{counterpartyId}": { "schema": { "$ref": "#/backend/entities/Counterparty" }, "description": "Financial entities involved in freelance requests." },
    "/freelance_diligences/{diligenceId}": { "schema": { "$ref": "#/backend/entities/FreelanceDiligence" }, "description": "Task management for freelance services." }
  }
}
