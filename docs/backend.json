
{
  "entities": {
    "Client": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Client",
      "type": "object",
      "description": "Represents a client (either individual or corporate) of the legal firm, storing their complete registration information.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "documentNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zipCode": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "documentNumber", "type", "createdAt"]
    },
    "Interview": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Interview",
      "type": "object",
      "description": "Captured details from a potential client intake or witness interview.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "type": { "type": "string", "enum": ["Inicial Trabalhista", "Cível", "Preparação de Testemunha"] },
        "status": { "type": "string", "enum": ["Em Rascunho", "Concluída", "Convertida em Processo"] },
        "interviewerId": { "type": "string" },
        "data": { "type": "object" },
        "aiSummary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "StaffProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StaffProfile",
      "type": "object",
      "description": "Represents a legal team member.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "isActive": { "type": "boolean" },
        "themePreferences": { "type": "object" }
      }
    },
    "Process": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Process",
      "type": "object",
      "description": "Details of a legal process.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "processNumber": { "type": "string" },
        "caseType": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "court": { "type": "string" },
        "responsibleStaffId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "structure": [
      { "path": "/staff_profiles/{staffId}", "definition": { "entityName": "StaffProfile", "schema": { "$ref": "#/backend/entities/StaffProfile" }, "description": "Staff profiles." } },
      { "path": "/clients/{clientId}", "definition": { "entityName": "Client", "schema": { "$ref": "#/backend/entities/Client" }, "description": "Client registration data." } },
      { "path": "/processes/{processId}", "definition": { "entityName": "Process", "schema": { "$ref": "#/backend/entities/Process" }, "description": "Legal process details." } },
      { "path": "/interviews/{interviewId}", "definition": { "entityName": "Interview", "schema": { "$ref": "#/backend/entities/Interview" }, "description": "Client intake interviews." } }
    ]
  }
}
