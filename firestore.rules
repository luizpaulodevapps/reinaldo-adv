
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * LexFlow ERP - Blindagem de Acesso RGMJ
     * Conforme diretriz: Se o usuário logou, ele tem permissão total.
     * Esta regra garante acesso absoluto para a conta do Dr. Reinaldo e sua equipe autorizada.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Regras explícitas para coleções de alto tráfego para evitar ambiguidades de permissão/índice
    match /interviews/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /leads/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /processes/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /clients/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /financial_titles/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /staff_profiles/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
