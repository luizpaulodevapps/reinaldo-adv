rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LexFlow ERP Security Rules - RGMJ Elite Edition
     * Blindagem de Acesso Absoluto para o Proprietário.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && (request.auth.token.email == 'luizao16@gmail.com' || request.auth.token.email == 'luizpaulo.dev.apps@gmail.com');
    }

    function getStaffRole() {
      return get(/databases/$(database)/documents/staff_profiles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isOwner() || (isSignedIn() && exists(/databases/$(database)/documents/staff_profiles/$(request.auth.uid)) && getStaffRole() == 'admin');
    }

    function isFinancial() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/staff_profiles/$(request.auth.uid)) && getStaffRole() == 'financial');
    }

    function isAssigned(staffId) {
      return isSignedIn() && (request.auth.uid == staffId || isOwner() || isAdmin());
    }

    // --- COLLECTION RULES ---

    match /staff_profiles/{staffId} {
      allow get, update: if isSignedIn() && (request.auth.uid == staffId || isOwner() || isAdmin());
      allow list, create, delete: if isOwner() || isAdmin();
    }

    match /clients/{clientId} {
      // Donos e Financeiro veem tudo. Advogados veem apenas os que são responsáveis.
      allow list, read: if isOwner() || isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && resource.data.responsibleStaffIds is list && request.auth.uid in resource.data.responsibleStaffIds;
      allow create, update: if isOwner() || isAdmin() || isFinancial();
      allow delete: if isOwner() || isAdmin();
    }

    match /processes/{processId} {
      allow list, read: if isOwner() || isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && resource.data.responsibleStaffId == request.auth.uid;
      allow create: if isOwner() || isAdmin() || (isSignedIn() && request.resource.data.responsibleStaffId == request.auth.uid);
      allow update: if isOwner() || isAdmin() || (isSignedIn() && resource.data.responsibleStaffId == request.auth.uid);
      allow delete: if isOwner() || isAdmin();
    }

    match /defendants/{defendantId} {
      allow list, read: if isOwner() || isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && resource.data.processResponsibleStaffId == request.auth.uid;
      allow create, update: if isOwner() || isAdmin() || (isSignedIn() && request.resource.data.processResponsibleStaffId == request.auth.uid);
      allow delete: if isOwner() || isAdmin();
    }

    match /leads/{leadId} {
      allow list, read: if isOwner() || isAdmin() || (isSignedIn() && request.auth.token.role == 'assistant');
      allow list, read: if isSignedIn() && resource.data.assignedStaffId == request.auth.uid;
      allow create: if isOwner() || isAdmin() || (isSignedIn() && request.resource.data.assignedStaffId == request.auth.uid);
      allow update: if isOwner() || isAdmin() || (isSignedIn() && resource.data.assignedStaffId == request.auth.uid);
      allow delete: if isOwner() || isAdmin();
    }

    match /hearings/{hearingId} {
      allow list, read: if isOwner() || isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && (resource.data.staffId == request.auth.uid || resource.data.processResponsibleStaffId == request.auth.uid);
      allow create, update: if isOwner() || isAdmin() || (isSignedIn() && (request.resource.data.staffId == request.auth.uid || request.resource.data.processResponsibleStaffId == request.auth.uid));
      allow delete: if isOwner() || isAdmin();
    }

    match /deadlines/{deadlineId} {
      allow list, read: if isOwner() || isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && (resource.data.staffId == request.auth.uid || resource.data.processResponsibleStaffId == request.auth.uid);
      allow create, update: if isOwner() || isAdmin() || (isSignedIn() && request.resource.data.staffId == request.auth.uid);
      allow delete: if isOwner() || isAdmin();
    }

    match /financial_titles/{financialTitleId} {
      // Separação de privilégios para evitar erro de permissão em listagens globais
      allow list, read: if isOwner() || isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && resource.data.processResponsibleStaffId == request.auth.uid;
      allow create, update: if isOwner() || isAdmin() || isFinancial();
      allow delete: if isOwner() || isAdmin();
    }

    match /staff_credits/{staffCreditId} {
      allow list, read: if isOwner() || isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && resource.data.staffId == request.auth.uid;
      allow create, update: if isOwner() || isAdmin() || isFinancial();
      allow delete: if isOwner() || isAdmin();
    }
  }
}