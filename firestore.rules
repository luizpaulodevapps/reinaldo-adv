
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * LexFlow ERP - Controle Soberano RGMJ
     * A autenticação é a chave única e absoluta para acesso aos dados da banca.
     * Permitimos leitura e escrita para qualquer usuário autenticado.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
