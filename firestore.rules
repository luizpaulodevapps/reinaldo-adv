rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RGMJ ADVOGADOS - SOBERANIA TOTAL (REVISÃO DEFINITIVA)
     * 
     * Diretriz: "Se logou, está permitido".
     * Este comando remove qualquer trava granular, garantindo acesso total 
     * a todos os módulos (Processos, Notificações, Financeiro, etc) para usuários autenticados.
     */

    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}