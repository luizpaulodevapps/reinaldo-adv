rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RGMJ ADVOGADOS - SOBERANIA OPERACIONAL
     * 
     * Filosofia: Se logou, tem acesso colaborativo aos dados da banca para garantir a 
     * fluidez processual. Restrições aplicadas apenas a notificações e perfis.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        (get(/databases/$(database)/documents/staff_profiles/$(request.auth.uid)).data.role == 'admin' || 
         get(/databases/$(database)/documents/staff_profiles/$(request.auth.uid)).data.isOwner == true);
    }

    // --- Collection Rules ---

    // Perfis de Equipe: Leitura para todos, escrita apenas pelo próprio usuário ou administradores
    match /staff_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isUser(userId) || isAdmin();
    }

    // Leads e Entrevistas: Soberania total para o rito de triagem
    match /leads/{leadId} {
      allow read, write: if isSignedIn();
      
      match /interviews/{interviewId} {
        allow read, write: if isSignedIn();
      }
      
      match /clientInterviews/{clientInterviewId} {
        allow read, write: if isSignedIn();
      }
    }

    // Clientes e Processos: Base de dados central colaborativa
    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    match /processes/{processId} {
      allow read, write: if isSignedIn();
    }

    // Agenda e Atos Judiciais
    match /hearings/{id} {
      allow read, write: if isSignedIn();
    }

    match /deadlines/{id} {
      allow read, write: if isSignedIn();
    }

    match /appointments/{id} {
      allow read, write: if isSignedIn();
    }

    match /diligences/{id} {
      allow read, write: if isSignedIn();
    }

    match /freelance_diligences/{id} {
      allow read, write: if isSignedIn();
    }

    // Financeiro e Logística
    match /financial_titles/{id} {
      allow read, write: if isSignedIn();
    }

    match /reimbursements/{id} {
      allow read, write: if isSignedIn();
    }

    match /freelancers/{id} {
      allow read, write: if isSignedIn();
    }

    match /counterparties/{id} {
      allow read, write: if isSignedIn();
    }

    // Estruturas de Apoio e Biblioteca Técnica
    match /courts/{id} {
      allow read, write: if isSignedIn();
    }

    match /checklists/{id} {
      allow read, write: if isSignedIn();
    }

    match /checklist_executions/{id} {
      allow read, write: if isSignedIn();
    }

    match /employees/{id} {
      allow read, write: if isSignedIn();
    }

    match /document_templates/{id} {
      allow read, write: if isSignedIn();
    }

    match /notification_templates/{id} {
      allow read, write: if isSignedIn();
    }

    match /settings/{id} {
      allow read, write: if isSignedIn();
    }

    match /activities/{id} {
      allow read, write: if isSignedIn();
    }

    // Notificações: Apenas o destinatário tem soberania sobre seus alertas
    match /notifications/{id} {
      allow read: if isSignedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
                            && resource.data.userId == request.auth.uid;
    }

    // --- Collection Group Rules (para queries globais de inteligência) ---

    match /{path=**}/interviews/{interviewId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/clientInterviews/{clientInterviewId} {
      allow read: if isSignedIn();
    }
  }
}