rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RGMJ ADVOGADOS - POLÍTICA DE SOBERANIA TOTAL
     * 
     * Conforme diretriz da cúpula: "Se logou, está permitido".
     * Este ecossistema opera em regime de confiança total entre os membros autenticados.
     * Toda a base de dados (Processos, Prazos, Financeiro, Triagem e Notificações) 
     * é acessível para leitura e escrita por qualquer colaborador com login ativo.
     */

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}