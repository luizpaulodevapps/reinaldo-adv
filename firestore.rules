rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RGMJ ADVOGADOS - SOBERANIA OPERACIONAL
     * 
     * Filosofia: Identidade baseada em E-mail para sincronismo com Google Workspace.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.email.lower();
    }

    function isUser(emailId) {
      return isSignedIn() && getEmail() == emailId;
    }

    function isAdmin() {
      return isSignedIn() && 
        (get(/databases/$(database)/documents/staff_profiles/$(getEmail())).data.role == 'admin' || 
         get(/databases/$(database)/documents/staff_profiles/$(getEmail())).data.isOwner == true);
    }

    // --- Collection Rules ---

    // Perfis de Equipe: ID do documento é o e-mail em minúsculas
    match /staff_profiles/{emailId} {
      allow read: if isSignedIn();
      allow write: if isUser(emailId) || isAdmin();
    }

    // Preferências de Notificação: Usuário acessa seu próprio ID
    match /notification_preferences/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Leads e Entrevistas
    match /leads/{leadId} {
      allow read, write: if isSignedIn();
      
      match /interviews/{interviewId} {
        allow read, write: if isSignedIn();
      }
      
      match /clientInterviews/{clientInterviewId} {
        allow read, write: if isSignedIn();
      }
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    match /processes/{processId} {
      allow read, write: if isSignedIn();
    }

    match /hearings/{id} {
      allow read, write: if isSignedIn();
    }

    match /deadlines/{id} {
      allow read, write: if isSignedIn();
    }

    match /appointments/{id} {
      allow read, write: if isSignedIn();
    }

    match /diligences/{id} {
      allow read, write: if isSignedIn();
    }

    match /freelance_diligences/{id} {
      allow read, write: if isSignedIn();
    }

    match /financial_titles/{id} {
      allow read, write: if isSignedIn();
    }

    match /reimbursements/{id} {
      allow read, write: if isSignedIn();
    }

    match /freelancers/{id} {
      allow read, write: if isSignedIn();
    }

    match /counterparties/{id} {
      allow read, write: if isSignedIn();
    }

    match /courts/{id} {
      allow read, write: if isSignedIn();
    }

    match /checklists/{id} {
      allow read, write: if isSignedIn();
    }

    match /checklist_executions/{id} {
      allow read, write: if isSignedIn();
    }

    match /employees/{id} {
      allow read, write: if isSignedIn();
    }

    match /document_templates/{id} {
      allow read, write: if isSignedIn();
    }

    match /notification_templates/{id} {
      allow read, write: if isSignedIn();
    }

    match /settings/{id} {
      allow read, write: if isSignedIn();
    }

    match /activities/{id} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Collection Group Rules ---

    match /{path=**}/interviews/{interviewId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/clientInterviews/{clientInterviewId} {
      allow read: if isSignedIn();
    }
  }
}