
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * LexFlow ERP - Controle Soberano via Login
     * Todo usuário autenticado tem permissão total de leitura e escrita.
     * Atualização: Índices compostos aplicados para consultas de entrevistas e leads.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
