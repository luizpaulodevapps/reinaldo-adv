rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * LexFlow ERP - Blindagem de Acesso RGMJ
     * Conforme diretriz soberana: Se o usuário logou, ele tem permissão total (CRUD).
     * Esta regra garante acesso absoluto para qualquer membro autenticado.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}