rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * LexFlow ERP - Soberania de Acesso RGMJ
     * Qualquer usuário autenticado via Google tem permissão total (CRUD) em todas as coleções.
     * Segurança baseada na identidade institucional.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}