rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LexFlow ERP Security Rules - RGMJ Elite Edition
     * Blindagem de Acesso Absoluto para o Proprietário.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && (
        request.auth.token.email == 'luizao16@gmail.com' || 
        request.auth.token.email == 'luizpaulo.dev.apps@gmail.com' ||
        request.auth.uid == '8g3l5AXA6gOuaGyMRcgmLefxCcE3'
      );
    }

    // --- SUPREMACIA: ACESSO TOTAL PARA O PROPRIETÁRIO ---
    // Esta regra garante que o Dono nunca receba "Permissão Insuficiente"
    match /{document=**} {
      allow read, write: if isOwner();
    }

    function getStaffRole() {
      return get(/databases/$(database)/documents/staff_profiles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/staff_profiles/$(request.auth.uid)) && getStaffRole() == 'admin';
    }

    function isFinancial() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/staff_profiles/$(request.auth.uid)) && getStaffRole() == 'financial');
    }

    // --- COLLECTION RULES PARA OUTROS USUÁRIOS ---

    match /staff_profiles/{staffId} {
      allow read, update: if isSignedIn() && request.auth.uid == staffId;
      allow list: if isAdmin();
    }

    match /clients/{clientId} {
      allow list, read: if isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && resource.data.responsibleStaffIds is list && request.auth.uid in resource.data.responsibleStaffIds;
      allow create, update: if isAdmin() || isFinancial();
      allow delete: if isAdmin();
    }

    match /processes/{processId} {
      allow list, read: if isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && resource.data.responsibleStaffId == request.auth.uid;
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.responsibleStaffId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.responsibleStaffId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /defendants/{defendantId} {
      allow list, read: if isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && resource.data.processResponsibleStaffId == request.auth.uid;
      allow create, update: if isAdmin() || (isSignedIn() && request.resource.data.processResponsibleStaffId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow list, read: if isAdmin() || (isSignedIn() && request.auth.token.role == 'assistant');
      allow list, read: if isSignedIn() && resource.data.assignedStaffId == request.auth.uid;
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.assignedStaffId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.assignedStaffId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /hearings/{hearingId} {
      allow list, read: if isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && (resource.data.staffId == request.auth.uid || resource.data.processResponsibleStaffId == request.auth.uid);
      allow create, update: if isAdmin() || (isSignedIn() && (request.resource.data.staffId == request.auth.uid || request.resource.data.processResponsibleStaffId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /deadlines/{deadlineId} {
      allow list, read: if isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && (resource.data.staffId == request.auth.uid || resource.data.processResponsibleStaffId == request.auth.uid);
      allow create, update: if isAdmin() || (isSignedIn() && request.resource.data.staffId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /financial_titles/{financialTitleId} {
      allow list, read: if isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && resource.data.processResponsibleStaffId == request.auth.uid;
      allow create, update, delete: if isAdmin() || isFinancial();
    }

    match /staff_credits/{staffCreditId} {
      allow list, read: if isAdmin() || isFinancial();
      allow list, read: if isSignedIn() && resource.data.staffId == request.auth.uid;
      allow create, update: if isAdmin() || isFinancial();
      allow delete: if isAdmin();
    }
  }
}